# Database (production uses SQLite)
DATABASE_URL="file:./data/hackerboard.db"

# Backend
NODE_ENV=development
PORT=3002

# Frontend
VITE_API_URL=http://localhost:3002/api

# Wien Live — Traffic. Without provider/key the tile stays in a configured empty state.
# Currently implemented provider: tomtom
TRAFFIC_PROVIDER=
TRAFFIC_API_KEY=
TRAFFIC_START_LAT=48.2061223
TRAFFIC_START_LON=16.4309681
TRAFFIC_DESTINATION_LAT=47.8150
TRAFFIC_DESTINATION_LON=16.2440

# Optional future event provider. The current implementation uses a clearly marked mock provider.
EVENTS_PROVIDER=mock

TZ=Europe/Vienna
